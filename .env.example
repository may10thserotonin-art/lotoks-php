# ─────────────────────────────────────────────────────
# Lotoks — Environment Configuration
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ⚠ NEVER commit .env to git — it contains secrets!
# ─────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lotoks
DB_USER=root
DB_PASS=

# ── App Settings ─────────────────────────────────────
APP_ENV=local              # 'local' or 'production'
APP_URL=http://localhost/lotoks
JWT_SECRET=change-this-to-a-random-secret
SESSION_LIFETIME=3600

# ── Email / SMTP ─────────────────────────────────────
# In production, set EMAIL_ENABLED=true to send real emails.
# In local/dev, EMAIL_ENABLED=false logs emails to logs/email.log
EMAIL_ENABLED=false
SMTP_HOST=mail.lotoks.co.za
SMTP_PORT=465
SMTP_USER=support@lotoks.co.za
SMTP_PASS=your-smtp-password-here
SMTP_ENCRYPT=ssl
SMTP_FROM=support@lotoks.co.za
SMTP_FROM_NAME=Lotoks Support
